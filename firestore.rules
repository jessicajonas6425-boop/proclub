rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.matches('(?i)^jessicajonas6425@gmail\\.com$') ||
        request.auth.token.email.matches('(?i)^proclub@x\\.com$') ||
        request.auth.token.email.matches('(?i)^well\\.tvl\\.577@gmail\\.com$') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwnerOfClub(clubId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/clubs/$(clubId)) && 
        get(/databases/$(database)/documents/clubs/$(clubId)).data.creatorId == request.auth.uid;
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Clubs Collection
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.creatorId == request.auth.uid && 
        request.resource.data.creatorId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Players Collection
    match /players/{playerId} {
      allow read: if true;
      allow create: if isAdmin() || isOwnerOfClub(request.resource.data.clubId);
      allow update: if isAdmin() || (
        isOwnerOfClub(resource.data.clubId) && 
        isOwnerOfClub(request.resource.data.clubId)
      );
      allow delete: if isAdmin() || isOwnerOfClub(resource.data.clubId);
    }

    // Tournaments Collection
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Matches Collection
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Standings Collection
    match /standings/{standingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News Collection
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Transfers Collection
    match /transfers/{transferId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (
        isSignedIn() && (
          resource.data.fromClubId == request.auth.uid || 
          get(/databases/$(database)/documents/clubs/$(resource.data.fromClubId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/clubs/$(resource.data.toClubId)).data.creatorId == request.auth.uid
        )
      );
      allow delete: if isAdmin();
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Protests Collection
    match /protests/{protestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwnerOfClub(request.resource.data.clubId);
      allow update: if isAdmin() || (isSignedIn() && isOwnerOfClub(resource.data.clubId));
      allow delete: if isAdmin();
    }
  }
}
